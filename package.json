{
  "name": "bux-spades",
  "version": "1.0.0",
  "description": "BUX Spades — multiplayer Spades (web + mobile)",
  "private": true,
  "scripts": {
    "dev": "./scripts/start-dev.sh",
    "start": "./scripts/start-dev.sh",
    "deploy:server": "cd server && flyctl deploy --app bux-spades-server --depot=false --now",
    "script:db:test": "node scripts/test-db-connection.js",
    "script:db:cleanup": "./scripts/cleanup-db.sh",
    "script:server:restart": "./scripts/restart-server.sh",
    "cap:sync": "cd client && npm run cap:sync",
    "cap:ios": "cd client && npm run cap:ios",
    "cap:android": "cd client && npm run cap:android",
    "apk:debug": "cd client && npm run build && npx cap sync android && cd android && ./gradlew assembleDebug",
    "ios:sync": "cd client && npm run build && npx cap sync ios",
    "ios:open": "open client/ios/App/App.xcworkspace",
    "apk:release": "cd client && npm run cap:sync && cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@prisma/client": "^6.11.1",
    "axios": "^1.12.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.3",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "prisma": "^6.11.1"
  }
}
